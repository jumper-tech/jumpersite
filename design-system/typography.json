{
  "heading": "Haffer",
  "body": "Haffer",
  "mono": "JetBrains Mono",
  "_jumper_custom": {
    "haffer": {
      "type": "variable",
      "format": "truetype-variations",
      "weight_range": "100-900",
      "files": {
        "normal": "haffer-variable.ttf",
        "italic": "haffer-italic.ttf"
      },
      "fallback": ["Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "sans-serif"]
    },
    "weight_classes": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    },
    "fluid_scale": {
      "h1": "clamp(1.5rem, 1.25rem + 1.25vw, 2.25rem)",
      "h2": "clamp(1.25rem, 1.125rem + 0.625vw, 1.75rem)",
      "h3": "clamp(1.125rem, 1rem + 0.625vw, 1.5rem)",
      "h4": "clamp(1rem, 0.9rem + 0.5vw, 1.25rem)",
      "body": "clamp(0.875rem, 0.8rem + 0.375vw, 1rem)"
    },
    "line_height": {
      "h1": 1.2,
      "h2": 1.3,
      "h3": 1.3,
      "h4": 1.4,
      "body": 1.6
    }
  }
}
